---
export interface Props {
	href: string;
	label: string;
	icon: string;
	variant?: "soft" | "swipe";
	target?: "_self" | "_blank" | "_parent" | "_top";
	rel?: string;
	ariaLabel?: string;
	class?: string;
}

const { href, label, icon, variant = "soft", target, rel, ariaLabel, class: className = "" } = Astro.props;

const computedRel = rel ?? (target === "_blank" ? "noreferrer" : undefined);
---

<a
	href={href}
	target={target}
	rel={computedRel}
	aria-label={ariaLabel ?? label}
	class:list={["action-link", `action-link--${variant}`, className]}
>
	<ion-icon class="action-icon" name={icon} aria-hidden="true"></ion-icon>
	<span>{label}</span>
</a>

<style>
	.action-link {
		display: inline-flex;
		align-items: flex-start;
		gap: 0.35rem;
		padding: 0.2rem 0.5rem;
		line-height: 1;
		border-radius: 9999px;
		text-decoration: none;
		color: var(--txt-1);
		position: relative;
		overflow: hidden;
		isolation: isolate;
		transition:
			color 0.25s ease,
			background-color 0.25s ease;
	}

	.action-link > span {
		display: block;
		line-height: 1;
	}

	.action-icon {
		display: block;
		font-size: 0.95rem;
		line-height: 1;
		transform: translateY(-0.05em);
		transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.25, 1);
	}

	.action-link:hover,
	.action-link:focus-visible {
		text-decoration: none;
	}

	.action-link:hover .action-icon,
	.action-link:focus-visible .action-icon {
		transform: translateY(calc(-0.05em - 1px)) rotate(-8deg);
	}

	.action-link--soft:hover,
	.action-link--soft:focus-visible {
		background-color: color-mix(in srgb, var(--clr-500) 12%, transparent);
		color: var(--clr-500);
	}

	.action-link--swipe::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(
			120deg,
			color-mix(in srgb, var(--clr-500) 10%, transparent),
			color-mix(in srgb, var(--clr-500) 28%, transparent)
		);
		transform: translateX(-110%);
		opacity: 0;
		transition:
			opacity 0.25s ease,
			transform 0.45s cubic-bezier(0.2, 0.7, 0.25, 1);
		z-index: -1;
	}

	.action-link--swipe:hover,
	.action-link--swipe:focus-visible {
		animation: actionNudge 0.5s cubic-bezier(0.2, 0.7, 0.25, 1);
	}

	.action-link--swipe:hover::before,
	.action-link--swipe:focus-visible::before {
		opacity: 1;
		transform: translateX(0);
	}

	@keyframes actionNudge {
		0% {
			transform: translateX(0);
		}

		40% {
			transform: translateX(-2px);
		}

		70% {
			transform: translateX(1px);
		}

		100% {
			transform: translateX(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.action-link,
		.action-link::before,
		.action-icon {
			animation: none;
			transition: none;
		}

		.action-link:hover .action-icon,
		.action-link:focus-visible .action-icon {
			transform: translateY(-0.05em);
		}
	}
</style>
