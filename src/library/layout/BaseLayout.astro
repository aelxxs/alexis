---
import "../styling/style.css";
import "../styling/reset.css";
import "../styling/code.css";

import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";

export interface Props {
	title: string;
	showTitle?: boolean;
	showHeader?: boolean;
	showFooter?: boolean;
	overwritePageTitle?: boolean;
}

const { title, overwritePageTitle = false } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<!-- <meta name="description" content="" /> -->
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- HTML Meta Tags -->
		<title>{overwritePageTitle ? title : `${title} — Alexis Vielma`}</title>
		<meta name="description" content="My little corner of the internet" />
		<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#1b1c22" media="(prefers-color-scheme: dark)" />

		<!-- Facebook Meta Tags -->
		<meta property="og:url" content="https://alexis.lol" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={overwritePageTitle ? title : `${title} — Alexis Vielma`} />
		<meta property="og:image" content="" />
		<meta property="og:description" content="My little corner of the internet" />
		<meta property="og:site_name" content="alexis.lol" />

		<!-- Twitter Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:domain" content="alexis.lol" />
		<meta property="twitter:url" content="https://alexis.lol" />
		<meta name="twitter:title" content={overwritePageTitle ? title : `${title} — Alexis Vielma`} />
		<meta name="twitter:description" content="My little corner of the internet" />
		<meta name="twitter:image" content="" />

		<ClientRouter />
		<LoadingIndicator color="var(--clr-500)" height="3px" threshold={600} />

		<script is:inline>
			const theme = localStorage.getItem("theme");

			document.documentElement.setAttribute("data-theme", theme ?? "light");

			document.addEventListener("astro:after-swap", () =>
				document.documentElement.setAttribute("data-theme", localStorage.getItem("theme") ?? "light"),
			);
		</script>

		<script is:inline>
			(() => {
				try {
					if (sessionStorage.getItem("initial-wipe-played") === "true") return;

					document.documentElement.setAttribute("data-initial-render", "true");

					addEventListener(
						"load",
						() => {
							setTimeout(() => {
								document.documentElement.removeAttribute("data-initial-render");
								sessionStorage.setItem("initial-wipe-played", "true");
							}, 400);
						},
						{ once: true },
					);
				} catch {
					// no-op when storage APIs are unavailable
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		<script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
		<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
		<style>
			@keyframes fadeOutUp {
				from {
					opacity: 1;
					transform: translateY(0);
				}

				to {
					opacity: 0;
					transform: translateY(-8px);
				}
			}

			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(16px);
				}

				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes fadeOutDown {
				from {
					opacity: 1;
					transform: translateY(0);
				}

				to {
					opacity: 0;
					transform: translateY(8px);
				}
			}

			@keyframes fadeInDown {
				from {
					opacity: 0;
					transform: translateY(-16px);
				}

				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
		</style>
		<style is:global>
			html[data-initial-render="true"] body::before {
				content: "";
				position: fixed;
				inset: 0;
				z-index: 9999;
				pointer-events: none;
				background: var(--bg-main);
				box-shadow: 0 4px 16px hsl(0 0% 0% / 0.08);
				animation: initialWipeReveal 820ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
			}

			@keyframes initialWipeReveal {
				from {
					transform: translateY(0%);
				}

				to {
					transform: translateY(100%);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				html[data-initial-render="true"] body::before {
					animation: none;
					opacity: 0;
				}
			}
		</style>
	</body>
</html>
