---
import Project from "@blocks/Project.astro";
import JobExperience from "@blocks/WorkExperience.astro";
import ActionLink from "@blocks/ActionLink.astro";
import MainLayout from "@layout/MainLayout.astro";

const jobs = [
	{
		title: "Front End Engineer",
		company: "AWS",
		companyUrl: "https://aws.com",
		description: "AWS — SMGS Ops DP&I",
		startDate: "Aug 2025",
		endDate: "Present",
		location: "Seattle, WA",
		languages: [],
	},
	{
		title: "Technology Director",
		company: "KJHK 90.7 FM",
		companyUrl: "https://kjhk.org",
		startDate: "Mar 2023",
		endDate: "May 2025",
		location: "Hyrbrid – Lawrence, KS",
		languages: [
			{
				url: "https://www.typescriptlang.org/",
				name: "TypeScript",
			},
			{
				url: "reactjs.org",
				name: "React Native",
			},
			{
				url: "https://wordpress.org/",
				name: "WordPress",
			},
		],
		description: "Mobile Development, RDS Encoding, Metadata Transmission",
	},
	{
		title: "Front End Engineer Intern",
		company: "Amazon",
		companyUrl: "https://amazon.com",
		startDate: "May 2024",
		endDate: "Aug 2024",
		location: "Seattle, WA",
		languages: [],
		description: "Stores — Home Innovation Team",
	},
	{
		title: "Software Engineer",
		company: "Lightbulb.ai",
		companyUrl: "https://lightbulb.ai",
		startDate: "May 2023",
		endDate: "May 2024",
		location: "Remote",
		languages: [
			{
				url: "https://www.typescriptlang.org/",
				name: "TypeScript",
			},
			{
				url: "reactjs.org",
				name: "React",
			},
		],
		description: "Call performance, measured by sentiment",
	},
];

type Repo = {
	name: string;
	description: string;
	stargazerCount: number;
	forkCount: number;
	primaryLanguage: {
		name: string;
		color: string;
	};
	pushedAt: string;
	url: string;
};

const repos: Repo[] = await fetch("https://ghapi.dstn.to/aelxxs/pinned")
	.then((res) => res.json())
	.then((res) => res.data);

const title = "Alexis Vielma";
const subtitle = "Front End Engineer @ AWS 🌧️";
---

<MainLayout {title} {subtitle} overwritePageTitle>
	<article class="flow mb:4">
		<h2 class="fs:xs txt:main">About Me</h2>
		<div>
			<p>I design and build accessible and inclusive experiences for the web.</p>
			<br />
			<p>
				On my free time, I enjoy collecting and spinning vinyl records, learning languages, watching Korean
				dramas, playing <a href="https://stardewvalley.net" target="_blank">Stardew Valley</a>, and taking long
				walks around Seattle, WA.
			</p>
		</div>
	</article>

	<article class="flow mb:4">
		<h2 class="fs:xs txt:main">Experience</h2>
		<div class="stack gap:2 mt:2">
			{jobs.map((job) => <JobExperience {...job} />)}
		</div>
		<p class="resume-wrap">
			<ActionLink
				href="../../resume.pdf"
				label="view resume"
				icon="document-text-outline"
				target="_blank"
				variant="soft"
			/>
		</p>
	</article>

	<article class="flow">
		<h2 class="fs:xs txt:main">Projects</h2>
		<div class="grid">
			{repos.map((repo) => <Project {...repo} />)}
		</div>
	</article>

	<style>
		.resume-wrap {
			text-align: right;
		}

		h2 {
			text-transform: uppercase;
			position: relative;
			color: var(--clr-400);
		}
	</style>
</MainLayout>
